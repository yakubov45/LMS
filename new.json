{
  "modules": [
    {
      "name": "auth",
      "endpoints": [
        {
          "name": "register",
          "method": "POST",
          "url": "/api/auth/register",
          "description": "Register a new user using university email. Assigns default role 'student'.",
          "request": {
            "email": "student@university.edu",
            "password": "securePassword123",
            "firstName": "John",
            "lastName": "Doe"
          },
          "response": {
            "uid": "fb_uid_12345",
            "token": "eyJhbG...jwt_token",
            "role": "student"
          }
        },
        {
          "name": "login",
          "method": "POST",
          "url": "/api/auth/login",
          "description": "Authenticate user and return JWT/Firebase token and role-based routing info.",
          "request": {
            "email": "student@university.edu",
            "password": "securePassword123"
          },
          "response": {
            "uid": "fb_uid_12345",
            "token": "eyJhbG...jwt_token",
            "role": "student"
          }
        },
        {
          "name": "updateSession",
          "method": "PUT",
          "url": "/api/auth/session",
          "description": "Refresh user session or update session claims (e.g., role upgrade).",
          "request": {
            "refreshToken": "fb_refresh_token_xyz"
          },
          "response": {
            "token": "eyJhbG...new_jwt_token",
            "expiresIn": 3600
          }
        }
      ]
    },
    {
      "name": "profile",
      "endpoints": [
        {
          "name": "getProfile",
          "method": "GET",
          "url": "/api/profile/me",
          "description": "Fetch current user profile including settings like dark mode preference.",
          "request": {},
          "response": {
            "uid": "fb_uid_12345",
            "role": "student",
            "firstName": "John",
            "lastName": "Doe",
            "theme": "dark",
            "image": "url"
          }
        },
        {
          "name": "updateProfile",
          "method": "PUT",
          "url": "/api/profile/me",
          "description": "Update user profile details and settings.",
          "request": {
            "theme": "dark",
            "bio": "3rd-year CS student."
          },
          "response": {
            "success": true,
            "updatedFields": [
              "theme",
              "bio"
            ]
          }
        },
        {
          "name": "deleteProfile",
          "method": "DELETE",
          "url": "/api/profile/me",
          "description": "Remove user profile (Admin or self-deletion).",
          "request": {},
          "response": {
            "success": true,
            "message": "Profile successfully marked for deletion."
          }
        }
      ]
    },
